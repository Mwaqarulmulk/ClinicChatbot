{
  "name": "whatsapp-ai-chatbot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "dev:whatsapp": "node --import tsx src/index.ts",
    "dev:test": "bun --hot src/index.test.ts",
    "start": "node --import tsx src/index.ts",
    "start:test": "bun src/index.test.ts",
    "seed:knowledge": "bun scripts/seed-knowledge.ts",
    "backup:db": "bun scripts/backup-db.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "docker:build": "docker build -t whatsapp-ai-chatbot .",
    "docker:run": "docker run -p 3000:8080 --env-file .env whatsapp-ai-chatbot"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@hono/node-server": "^1.19.6",
    "@lancedb/lancedb": "^0.22.0",
    "@libsql/client": "^0.15.15",
    "@sentry/node": "^10.53.1",
    "baileys": "^7.0.0-rc11",
    "drizzle-orm": "^0.45.1",
    "groq-sdk": "^0.33.0",
    "hono": "^4.10.6",
    "pino": "^10.1.0",
    "qrcode-terminal": "^0.12.0",
    "tsx": "^4.21.0",
    "zod": "^4.1.12"
  },
  "optionalDependencies": {
    "@lancedb/lancedb-linux-x64-gnu": "^0.27.2",
    "@libsql/linux-x64-gnu": "^0.5.29"
  },
  "overrides": {
    "protobufjs": "^7.5.7",
    "file-type": "^21.3.1",
    "esbuild": "^0.25.12"
  },
  "devDependencies": {
    "@types/bun": "^1.3.1",
    "@types/node": "^25.7.0",
    "@types/qrcode-terminal": "^0.12.2",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.2",
    "typescript": "^5.9.3"
  }
}
