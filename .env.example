# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# For Fly.io production, set secrets with:
#   fly secrets set KEY=value
# Non-secret values live in fly.toml [env].
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── Security ──────────────────────────────────────────────────────────────────
# Protects /admin/* HTTP endpoints via the x-admin-key header.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=

# ── WhatsApp ──────────────────────────────────────────────────────────────────
WHATSAPP_ENABLED=true
WHATSAPP_AUTH_DIR=.data/baileys-auth

# Comma-separated list of admin phone numbers (international format, digits only)
# e.g. 923001234567,923009876543
ADMIN_PHONE_NUMBERS=

# ── AI (Groq) ─────────────────────────────────────────────────────────────────
# Free API key: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
AI_TEMPERATURE=0.4

# ── Database (libSQL / Turso) ─────────────────────────────────────────────────
# Local development: use a file-based SQLite database
TURSO_DATABASE_URL=file:.data/local.db
# Production with Turso (https://turso.tech - free tier available):
# TURSO_DATABASE_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN is required for remote libsql:// or wss:// databases.
# Create one with: turso db tokens create your-database
# TURSO_AUTH_TOKEN=your-turso-auth-token
TURSO_AUTH_TOKEN=

# ── RAG / Knowledge Base (LanceDB) ────────────────────────────────────────────
LANCEDB_URI=.data/lancedb
RAG_TABLE=business_knowledge
EMBEDDING_DIMENSIONS=256

# Optional: plug in an OpenAI-compatible embedding API for better semantic search
# Without this, a local character n-gram hash is used (good enough for development)
EMBEDDING_API_URL=
EMBEDDING_API_KEY=

# ── Business Configuration ────────────────────────────────────────────────────
DEFAULT_BUSINESS_ID=default
DEFAULT_BUSINESS_NAME=Demo Clinic
DEFAULT_TIMEZONE=Asia/Karachi
BUSINESS_OPEN_HOUR=9
BUSINESS_CLOSE_HOUR=18
APPOINTMENT_DURATION_MINUTES=30

# ── Reminders ─────────────────────────────────────────────────────────────────
# How many minutes before an appointment to send a WhatsApp reminder
REMINDER_LEAD_MINUTES=60

# ── Human Handoff ─────────────────────────────────────────────────────────────
# Comma-separated keywords that trigger escalation to a human agent
HUMAN_HANDOFF_KEYWORDS=human,agent,representative,admin,owner

# ── Error Monitoring (Sentry) ─────────────────────────────────────────────────
# Free tier: https://sentry.io/signup
# Leave empty to disable error tracking
SENTRY_DSN=
