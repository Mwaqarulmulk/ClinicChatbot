NODE_ENV=development
PORT=3000
LOG_LEVEL=info
ADMIN_API_KEY=change-me-in-production

# WhatsApp
WHATSAPP_ENABLED=true
WHATSAPP_AUTH_DIR=.data/baileys-auth
ADMIN_PHONE_NUMBERS=923001234567

# AI
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
AI_TEMPERATURE=0.4

# Database: use local libSQL file in development or Turso in production.
TURSO_DATABASE_URL=file:.data/local.db
TURSO_AUTH_TOKEN=

# RAG
LANCEDB_URI=.data/lancedb
RAG_TABLE=business_knowledge
EMBEDDING_DIMENSIONS=256
EMBEDDING_API_URL=
EMBEDDING_API_KEY=

# Business defaults
DEFAULT_BUSINESS_ID=default
DEFAULT_BUSINESS_NAME=Demo Clinic
DEFAULT_TIMEZONE=Asia/Karachi
BUSINESS_OPEN_HOUR=9
BUSINESS_CLOSE_HOUR=18
APPOINTMENT_DURATION_MINUTES=30
REMINDER_LEAD_MINUTES=60
HUMAN_HANDOFF_KEYWORDS=human,agent,representative,admin,owner
